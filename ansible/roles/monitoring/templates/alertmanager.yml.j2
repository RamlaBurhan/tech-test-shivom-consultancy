{# jinja2: trim_blocks:True, lstrip_blocks:True #}
route:
  group_by: ['alertname', 'service']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  receiver: 'default'

receivers:
  - name: 'default'
{% if alertmanager_slack_webhook | default('') | length > 0 %}
    slack_configs:
      - api_url: '{{ alertmanager_slack_webhook }}'
        channel: '#alerts'
        send_resolved: true
{% endif %}


inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'instance']
